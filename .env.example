# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orders_db

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Service URLs
AUTH_SERVICE_URL=http://localhost:8006
PRODUCT_SERVICE_URL=http://localhost:8001
INVENTORY_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8005

# Application
SERVICE_PORT=8004
LOG_LEVEL=INFO

# Cart settings
CART_EXPIRY_DAYS=30

# Order settings
TAX_RATE=0.08
SHIPPING_COST=9.99
FREE_SHIPPING_THRESHOLD=100.00

# JWT (for local validation if needed)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
